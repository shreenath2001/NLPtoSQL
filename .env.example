# Natural Language to SQL Hub - Environment Template

# 1. Your OpenAI API Key (Required for NL translation)
OPENAI_API_KEY=your_openai_api_key_here

# 2. Database Encryption Key (Required for secure credential storage)
# This will be automatically generated by the app if left blank, 
# but must be the same across restarts to read old credentials.
DB_ENCRYPTION_KEY=your_32_byte_base64_encoded_key_here
